# Contentful Content Delivery API credentials.
#
# Copy this file to `.env.local` (git-ignored) and fill in real values:
#   cp apps/web/.env.example apps/web/.env.local
#
# Use a *Content Delivery API* access token (read-only) — NOT a Management
# personal token (`CFPAT-…`), which the Delivery API rejects with
# AccessTokenInvalid. Generate it under: Space → Settings → API keys.
# https://www.contentful.com/developers/docs/references/content-delivery-api/

CONTENTFUL_SPACE_ID=
CONTENTFUL_ACCESS_TOKEN=
CONTENTFUL_ENVIRONMENT=master

# Formspree endpoint the contact form submits to. Create a form at
# https://formspree.io and paste its endpoint URL here. Exposed to the browser
# (NEXT_PUBLIC_) because the form submits client-side via fetch.
# https://help.formspree.io/sections/building-your-form
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/your-form-id

# Mixpanel project token for product analytics. This is an ingestion (write-only)
# token, client-exposed by design (NEXT_PUBLIC_) — it ships in the browser bundle,
# like a GA measurement ID. It is NOT a secret and grants no read/account access;
# exposure only risks event spoofing, not data access. Even so, keep the real
# value in .env.local (and your host's env vars) — not committed here — matching
# the Formspree convention above. Tracking stays consent-gated: Mixpanel
# initialises opted-out and only sends events after the visitor grants the
# "analytics" cookie category. Leave blank to disable analytics locally.
# Find it at mixpanel.com -> Project Settings -> Project Token.
NEXT_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-project-token
